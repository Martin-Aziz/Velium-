# Core
NODE_ENV=development
LOG_LEVEL=info

# Gateway
GATEWAY_PORT=8080
MASTER_API_KEYS=dgk_dev_local_key
LLM_SERVICE_URL=http://llm:8000
RENDERER_SERVICE_URL=http://renderer:3001

# LLM service
LLM_SERVICE_PORT=8000
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=

# Renderer service
RENDERER_PORT=3001

# Data services
POSTGRES_USER=velium
POSTGRES_PASSWORD=velium
POSTGRES_DB=velium
DATABASE_URL=postgresql://velium:velium@postgres:5432/velium
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222

# Security
JWT_SECRET=replace-with-a-strong-secret-of-at-least-32-chars
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
