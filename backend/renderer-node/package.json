  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.12.12",
    "tsx": "4.10.5",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
