{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://velium.dev/schemas/generate-request.schema.json",
  "title": "GenerateRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt", "outputFormats"],
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 10,
      "maxLength": 8000
    },
    "outputFormats": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "type": "string",
        "enum": ["docx", "markdown"]
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "documentTitle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "accentColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "fontFamily": {
          "type": "string",
          "minLength": 2,
          "maxLength": 40
        }
      }
    }
  }
}
